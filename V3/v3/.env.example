# === Azure AD (obligatoire) ===
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# === Base de donnees ===
DATABASE_URL=sqlite+aiosqlite:///data/phishing_agent.db
# Pour PostgreSQL : postgresql+asyncpg://user:password@localhost:5432/phishing_agent

# === API REST ===
API_HOST=0.0.0.0
API_PORT=8080

# === Serveur distant (VM Linux) ===
PHISHING_SERVER=http://192.168.237.133:8000

# === Scan ===
SCAN_DEFAULT_EMAILS=25
SCAN_MAX_EMAILS=100
SCAN_INTERVAL_MINUTES=60
RULES_FILE=config/rules.yaml

# === General ===
LOG_LEVEL=INFO
DATA_DIR=data
